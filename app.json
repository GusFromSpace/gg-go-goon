{
  "expo": {
    "name": "GG",
    "slug": "gg-go-goon",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "gg",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a0d0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gofromspace.gg",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "GG sends you scheduled wellness reminders.",
        "NSFaceIDUsageDescription": "GG uses Face ID to keep your sessions private."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "monochromeImage": "./assets/adaptive-icon-monochrome.png",
        "backgroundColor": "#1a0d0a"
      },
      "package": "com.gofromspace.gg",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon-monochrome.png",
          "color": "#1a0d0a",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "94d119db-a62e-4fee-b0e9-3f1b133ccf99"
      }
    }
  }
}
